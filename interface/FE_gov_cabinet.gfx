###########################################################################
# 国家政府领导组 - 部长立绘注册
# 约定：每位可任命的部长需要一张 GFX_Portrait_<角色token> 立绘，
#       面板里 GetGovPortrait_* 会自动解析 GFX_Portrait_[token]。
# 下面是示例（堤亚穆帝国 路德维希·休伊特，财政部长）。
# 之后新增部长，照此再加一条即可。
###########################################################################

spriteTypes = {

	# —— 示例：堤亚穆帝国 路德维希·休伊特（财政部长）——
	spriteType = {
		name = "GFX_Portrait_TIA_Ludwig_Hewitt"
		texturefile = "gfx/leaders/TIA/TIA_Ludwig_Hewitt.dds"
	}
}
